{
  "name": "socialsignin/webhook-sample-client",
  "description": "Example client for webhook-service",
  "license": "MIT",
  "require": {
    "php": ">=8.2",
    "slim/slim": "^3.6",
    "psr/log": "^1|^2",
    "ramsey/uuid": "^3.6.1",
    "monolog/monolog": "^1.22.1"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.0",
    "mockery/mockery": "^1.0",
    "php-parallel-lint/php-parallel-lint": "*",
    "psalm/phar": "*",
    "squizlabs/php_codesniffer": "^4.0"
  },
  "authors": [
    {
      "name": "Technical Team",
      "email": "technical@orlo.tech"
    }
  ],
  "autoload": {
    "psr-4": {
      "SocialSignIn\\WebhookClient\\": "src"
    }
  },
  "scripts": {
    "lint": "@php vendor/bin/parallel-lint --exclude vendor .",
    "phpunit": "@php vendor/bin/phpunit",
    "psalm": "@php vendor/bin/psalm.phar src",
    "phpcs": "@php -d grpc.enable_fork_support=1 -d grpc.poll_strategy=epoll1 ./vendor/bin/phpcs --parallel=$(nproc --all) ./src ./tests",
    "phpcbf": "@php -d grpc.enable_fork_support=1 -d grpc.poll_strategy=epoll1 ./vendor/bin/phpcbf --parallel=$(nproc --all) ./src ./tests",
    "test": [
      "@lint",
      "@phpunit"
    ]
  }
}
